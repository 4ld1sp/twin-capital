// Trade Collection Table for Prisma

model Trade {
  id              Int      @id @default(autoincrement())
  entryDate       DateTime @db.Date
  entryTime       String?
  asset           String
  entryPrice      Decimal  @db.Decimal(20, 8)
  exitPrice       Decimal? @db.Decimal(20, 8)
  positionSize    Decimal  @db.Decimal(20, 2)
  positionQty     String?
  side            String   // LONG / SHORT
  leverage        Int      @default(1)
  profitLossUsd  Decimal  @db.Decimal(20, 2) @default(0)
  profitLossPct  Decimal  @db.Decimal(10, 4) @default(0)
  timeframe       String   // 15m, 1H, 4H, 1D
  marketCondition String   // Trending, Ranging, Volatile
  signal          String?
  notes           String?  @db.Text
  status          String   // WIN, LOSS, OPEN
  createdAt       DateTime @default(now())
}

